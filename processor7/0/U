FoamFile
{
    format      ascii;
    class       volVectorField;
    location    "0";
    object      U;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 1 -1 0 0 0 0];

internalField   uniform (13 0 0);

boundaryField
{
    inlet
    {
        type            fixedValue;
        value           uniform (13 0 0);
    }
    outlet
    {
        type            inletOutlet;
        inletValue      nonuniform List<vector> 0();
        value           nonuniform List<vector> 0();
    }
    sides
    {
        type            slip;
    }
    topBottom
    {
        type            slip;
    }
    bajaSurface
    {
        type            noSlip;
    }
    procBoundary7to5
    {
        type            processor;
        value           uniform (13 0 0);
    }
    procBoundary7to6
    {
        type            processor;
        value           uniform (13 0 0);
    }
}


