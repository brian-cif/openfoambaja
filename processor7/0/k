FoamFile
{
    format      ascii;
    class       volScalarField;
    location    "0";
    object      k;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 2 -2 0 0 0 0];

internalField   uniform 0.63;

boundaryField
{
    inlet
    {
        type            fixedValue;
        value           uniform 0.63;
    }
    outlet
    {
        type            inletOutlet;
        inletValue      nonuniform List<scalar> 0();
        value           nonuniform List<scalar> 0();
    }
    sides
    {
        type            slip;
    }
    topBottom
    {
        type            slip;
    }
    bajaSurface
    {
        type            kLowReWallFunction;
        value           nonuniform List<scalar> 0();
    }
    procBoundary7to5
    {
        type            processor;
        value           uniform 0.63;
    }
    procBoundary7to6
    {
        type            processor;
        value           uniform 0.63;
    }
}


