FoamFile
{
    format      ascii;
    class       volScalarField;
    location    "0";
    object      omega;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 0 -1 0 0 0 0];

internalField   uniform 30;

boundaryField
{
    inlet
    {
        type            fixedValue;
        value           nonuniform List<scalar> 0();
    }
    outlet
    {
        type            inletOutlet;
        inletValue      uniform 30;
        value           uniform 30;
    }
    sides
    {
        type            slip;
    }
    topBottom
    {
        type            slip;
    }
    bajaSurface
    {
        type            omegaWallFunction;
        value           nonuniform List<scalar> 0();
    }
    procBoundary3to0
    {
        type            processor;
        value           uniform 30;
    }
    procBoundary3to1
    {
        type            processor;
        value           uniform 30;
    }
    procBoundary3to2
    {
        type            processor;
        value           uniform 30;
    }
}


